{
  "expo": {
    "name": "Limbo",
    "slug": "limbo",
    "scheme": "limbo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "ios": {
      "bundleIdentifier": "com.limbosocial.app",
      "buildNumber": "4",
      "supportsTablet": true,
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#111827",
        "tabletImage": "./assets/splash-icon.png"
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos and videos for your responses",
        "NSPhotoLibraryUsageDescription": "Choose photos and videos for your responses",
        "NSMicrophoneUsageDescription": "Record audio for your responses",
        "NSPhotoLibraryAddUsageDescription": "Save photos and videos to your library",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:limbo.social"
      ]
    },
    "android": {
      "package": "com.limbosocial.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#111827",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": {
            "scheme": "https",
            "host": "limbo.social",
            "pathPrefix": "/invite"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#111827"
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "cef79c8c-f8ec-4213-a015-16e3ee1d38d2"
      }
    },
    "owner": "mjhemker"
  }
}
